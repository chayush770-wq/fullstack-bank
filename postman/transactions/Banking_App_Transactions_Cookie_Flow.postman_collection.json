{
  "info": {
    "_postman_id": "6c10961e-a367-41e3-b477-fe9ca1bf8979",
    "name": "Banking App - Transactions Cookie Flow",
    "description": "Transactions tests for HttpOnly Cookie JWT. Run Auth Cookie Flow first and make sure the last request logs in A.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 A Transfers Money To B",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/transactions",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "transactions"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n    \"recipientEmail\": \"{{emailB}}\",\n    \"amount\": 100,\n    \"reason\": \"Postman automation test transfer from A to B\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Transfer A to B status is 201\", function () { pm.response.to.have.status(201); });",
              "const response = pm.response.json();",
              "pm.test(\"Transfer response has transaction\", function () { pm.expect(response.transaction).to.exist; });",
              "pm.test(\"Transfer response has newBalance\", function () { pm.expect(response.newBalance).to.exist; });",
              "pm.environment.set(\"transactionId\", response.transaction.id || response.transaction._id);",
              "pm.environment.set(\"userANewBalance\", response.newBalance);"
            ]
          }
        }
      ]
    },
    {
